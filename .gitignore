# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
out/
.turbo/
*.tsbuildinfo

# Native build artifacts
**/local.properties

# Capacitor generated web assets
apps/*/android/app/src/main/assets/public/
apps/*/ios/App/App/public/

# Resources copied by build pipeline (regenerated each build from tenants/<code>/assets/)
apps/*/resources/

# Secrets - NEVER COMMIT
*.keystore
*.jks
*.p12
*.pem
*.key
google-services.json
GoogleService-Info.plist
.env
.env.local
.env.*.local
tenants/*/google-services.json
tenants/*/GoogleService-Info.plist
tenants/*/secrets/

# Android signing config (created locally, contains keystore refs)
apps/*/android/signing.gradle
apps/*/android/key.properties

# Build script backup
apps/*/capacitor.config.ts.bak

# IDE
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/
# Auto-generated tenant runtime config (contains API token from .env, must NOT be committed)
apps/*/src/tenant.generated.ts
