# Build-time secrets used by scripts/build-tenant.ts
# Copy this file to .env and fill in. Never commit .env.

# Path to OyaSync upload keystore directory on this machine
OYASYNC_KEYSTORE_PATH=C:/oyasync-keystores

# Per-tenant keystore password (loaded from password manager)
# IMPORTANT: This must match the password used when generating the keystore.
OYASYNC_KEYSTORE_PASSWORD=

# Key alias inside the keystore (matches what was used in keytool -genkeypair -alias)
OYASYNC_KEY_ALIAS=villagechief-customer