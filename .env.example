# OYASYNC keystore signing - required for release APK builds
OYASYNC_KEYSTORE_PATH=C:\path\to\keystore\folder
OYASYNC_KEYSTORE_PASSWORD=<keystore-password>
OYASYNC_KEY_ALIAS=<tenant>-customer

# Per-tenant Frappe API tokens - used by the customer app to fetch menu/branches.
# Format: <TENANT_CODE_UPPER>_API_TOKEN=api_key:api_secret
# Generate via: bench --site <site> console -> create user -> generate_keys()
# Use a low-privilege user (e.g. role=Item Manager) - token is bundled in the APK.
VILLAGECHIEF_API_TOKEN=<api_key>:<api_secret>